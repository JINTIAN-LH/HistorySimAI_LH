{
  "version": 1,
  "description": "各地动态规则配置。namePattern 为正则表达式字符串，按 regionRules 顺序匹配，states 按顺序命中后返回。",
  "regionRules": [
    {
      "namePattern": "江淮|沿江",
      "default": {
        "threat": "critical",
        "status": "金军压力犹存，沿江防线需持续戒备。"
      },
      "states": [
        {
          "whenAny": [
            { "metric": "borderThreat", "op": ">=", "value": 75 },
            { "metric": "militaryStrength", "op": "<=", "value": 45 }
          ],
          "threat": "critical",
          "status": "沿江守线告急，敌情频仍，需尽快补充军饷与援军。"
        },
        {
          "whenAll": [
            { "metric": "borderThreat", "op": "<=", "value": 45 },
            { "metric": "militaryStrength", "op": ">=", "value": 65 }
          ],
          "threat": "medium",
          "status": "江防暂稳，但仍需持续警戒金军动向。"
        }
      ]
    },
    {
      "namePattern": "江淮|河南",
      "default": {
        "threat": "high",
        "status": "兵火与流民问题仍需持续处置。"
      },
      "states": [
        {
          "whenAny": [
            { "metric": "disasterLevel", "op": ">=", "value": 70 },
            { "metric": "civilMorale", "op": "<=", "value": 40 },
            { "metric": "unrest", "op": ">=", "value": 30 }
          ],
          "threat": "high",
          "status": "兵火与流民压力并存，若赈济不足局势将迅速恶化。"
        },
        {
          "whenAll": [
            { "metric": "disasterLevel", "op": "<=", "value": 45 },
            { "metric": "civilMorale", "op": ">=", "value": 55 }
          ],
          "threat": "medium",
          "status": "地方情势有所缓和，州县秩序正逐步恢复。"
        }
      ]
    },
    {
      "namePattern": "山东",
      "default": {
        "threat": "medium",
        "status": "军务尚可控，但仍需严防局部哗变反复。"
      },
      "states": [
        {
          "whenAny": [
            { "metric": "militaryStrength", "op": "<=", "value": 50 },
            { "metric": "unrest", "op": ">=", "value": 28 }
          ],
          "threat": "high",
          "status": "军纪与饷银压力偏高，兵变隐患依旧存在。"
        }
      ]
    },
    {
      "namePattern": "两浙|江南|湖广",
      "default": {
        "threat": "low",
        "status": "税粮产出稳定，仍是行在财政与粮运的主要支撑。"
      },
      "states": [
        {
          "whenAny": [
            { "metric": "treasury", "op": "<=", "value": 250000 },
            { "metric": "corruptionLevel", "op": ">=", "value": 70 }
          ],
          "threat": "medium",
          "status": "税赋与转运承压，财政回流效率明显下滑。"
        }
      ]
    },
    {
      "namePattern": "四川",
      "default": {
        "threat": "low",
        "status": "整体安稳，可作为战略后方与调度区域。"
      },
      "states": [
        {
          "whenAny": [
            { "metric": "unrest", "op": ">=", "value": 35 }
          ],
          "threat": "medium",
          "status": "地方治安波动，需提前防范土司与流民联动。"
        }
      ]
    }
  ]
}
